{
  "name": "educrm-monorepo",
  "version": "1.0.0",
  "description": "EduCRM - Full-Stack Education CRM System",
  "private": true,
  "scripts": {
    "dev:backend":  "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all":  "cd backend && npm install --legacy-peer-deps && cd ../frontend && npm install --legacy-peer-deps",
    "build:backend":  "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start:prod:backend": "cd backend && npm run start:prod"
  }
}
